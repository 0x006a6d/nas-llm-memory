{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "\"{{HOME}}/claude-config/hooks/session_start.sh\"" }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          { "type": "command", "command": "python3 \"{{HOME}}/claude-config/hooks/spool_write.py\"" }
        ]
      }
    ]
  }
}
